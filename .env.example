# --- BACKEND (eduai-ecosystem/backend) ---
# Gemini API Key from Google AI Studio
GEMINI_KEY=your_gemini_api_key_here
MODEL=gemini-2.5-flash

# Database URL
DATABASE_URL=DB_URL

# --- FRONTEND (eduai-ecosystem/frontend) ---
# The URL where your backend is running (use your local IP for physical device testing)
EXPO_PUBLIC_API_URL=http://localhost:8080
